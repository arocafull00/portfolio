---
const currentYear = new Date().getFullYear()
---

<footer
  class="mx-auto mb-6 w-full max-w-[min(100%,1120px)] px-4 sm:mb-8 sm:px-6 md:mb-10 lg:px-8 rounded-lg shadow bg-black/5 dark:bg-black/20 backdrop-blur-lg"
>
  <div
    class="flex w-full min-w-0 flex-col items-center gap-4 py-4 text-center sm:py-5 md:flex-row md:items-center md:justify-between md:gap-6 md:py-5 md:text-left"
  >
    <span
      class="inline-block max-w-prose text-sm text-balance text-yellow-800/90 dark:text-yellow-200/90"
      >© {currentYear}
      <a
        href="https://adrianrocafull.es"
        class="rounded-sm underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950"
        >Adrian Rocafull</a
      >.
    </span>
    <ul
      class="flex max-w-full flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm font-medium dark:text-white/90 md:shrink-0 md:justify-end"
    >
      <li>
        <a
          href="#about-me"
          class="rounded-sm inline-flex underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950"
          >About me</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="rounded-sm inline-flex underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400/80 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950"
          >Contact</a
        >
      </li>
    </ul>
  </div>
</footer>
