---
import GitHub from "src/icons/GitHub.astro";
import LinkButton from "./LinkButton.astro";
import type { IFreelanceProject } from "../interfaces/IProjectItem";
import Carousel from "./Carousel.astro";

interface Props {
  projectItemData: IFreelanceProject;
}
const { projectItemData } = Astro.props;
const { title, description, tags, link, github, images } = projectItemData;
const imageList = images.filter(
  (src) => typeof src === "string" && src.trim() !== ""
);
---

<article class="min-w-0">
  <h3
    class="text-2xl font-semibold text-pretty text-yellow-400 dark:text-yellow-400 mb-2"
  >
    {title}
  </h3>
  <p class="text-lg mb-4 text-pretty">{description}</p>
  <ul class="flex gap-2 flex-row flex-wrap mb-2">
    {
      tags.map((tag: { name: string; class: string; icon: any }) => (
        <li>
          <span
            class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
          >
            <tag.icon class="size-4 shrink-0" aria-hidden="true" />
            {tag.name}
          </span>
        </li>
      ))
    }
  </ul>
  {
    imageList.length > 1 ? (
      <Carousel carouselImages={imageList} imageAltBase={title} />
    ) : imageList.length === 1 ? (
      <img
        loading="lazy"
        width={1920}
        height={1080}
        src={imageList[0]}
        alt={`${title} — screenshot`}
        class="rounded-lg w-full max-h-[24rem] object-contain bg-black/20"
      />
    ) : (
      <p class="text-sm py-5 text-yellow-300">
        Screenshots not shown due to privacy policies.
      </p>
    )
  }
  <footer class="flex gap-x-4 items-end justify-start mt-4 flex-wrap">
    {
      github && (
        <LinkButton href={github}>
          <GitHub class="size-6 shrink-0" aria-hidden="true" />
          View Source
        </LinkButton>
      )
    }
    {
      link && (
        <LinkButton href={link}>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
            aria-hidden="true"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M19.5 7a9 9 0 0 0 -7.5 -4a8.991 8.991 0 0 0 -7.484 4" />
            <path d="M11.5 3a16.989 16.989 0 0 0 -1.826 4" />
            <path d="M12.5 3a16.989 16.989 0 0 1 1.828 4" />
            <path d="M19.5 17a9 9 0 0 1 -7.5 4a8.991 8.991 0 0 1 -7.484 -4" />
            <path d="M11.5 21a16.989 16.989 0 0 1 -1.826 -4" />
            <path d="M12.5 21a16.989 16.989 0 0 0 1.828 -4" />
            <path d="M2 10l1 4l1.5 -4l1.5 4l1 -4" />
            <path d="M17 10l1 4l1.5 -4l1.5 4l1 -4" />
            <path d="M9.5 10l1 4l1.5 -4l1.5 4l1 -4" />
          </svg>
          Go to Website
        </LinkButton>
      )
    }
  </footer>
</article>
