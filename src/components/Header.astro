---
import Hamburguer from "src/icons/Hamburguer.astro";
import Cross from "src/icons/Cross.astro";

const navLinkClass =
  "rounded-sm outline-offset-2 transition-[color,box-shadow] duration-200 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400/90 focus-visible:ring-offset-2 focus-visible:ring-offset-[#181822]";
---

<header
  class="flex justify-start items-start md:justify-center md:items-center h-[70px] p-3 w-full md:w-[800px] xl:w-[810px]
    fixed top-0 right-0 sm:right-auto z-[99999] bg-[#181822f1] text-[#e5ebf3]
    rounded-b-xl border-b border-[#ffffff60]
    transition-[height,box-shadow,background-color] duration-500 ease-out
    overflow-hidden
    "
>
  <nav
    aria-label="Primary"
    class="hidden md:flex sm:w-full sm:justify-between sm:align-items-center sm:gap-11 sm:opacity-80 sm:text-xl"
  >
    <a href="#home" class={navLinkClass} aria-label="Home">Home</a>
    <a href="#experience" class={navLinkClass} aria-label="Work experience"
      >Experience</a
    >
    <a
      href="#freelance-projects"
      class={navLinkClass}
      aria-label="Freelance projects">Freelance projects</a
    >
    <a href="#about-me" class={navLinkClass} aria-label="About me">About</a>
    <a href="#contact" class={navLinkClass} aria-label="Contact">Contact</a>
  </nav>
  <nav
    aria-label="Primary mobile"
    class="flex justify-between items-start flex-col w-full flex-wrap gap-7 p-2 md:hidden"
  >
    <div class="w-full flex justify-between items-center">
      <a href="#home" class={navLinkClass} aria-label="Home">Home</a>
      <button
        type="button"
        id="open-button"
        class="relative rounded-sm p-1 text-[#e5ebf3] outline-offset-2 transition-[color] duration-200 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400/90 focus-visible:ring-offset-2 focus-visible:ring-offset-[#181822]"
        aria-expanded="false"
        aria-controls="items-sm-navbar"
        aria-label="Open menu"
      >
        <Hamburguer
          class="size-6 transition-[opacity] duration-200 opacity-100 absolute top-2/4 right-1/2 translate-x-[-50%] translate-y-[-50%]"
        />
        <Cross
          class="size-6 opacity-0 transition-[opacity] duration-200 absolute top-2/4 right-1/2 translate-x-[-50%] translate-y-[-50%]"
        />
      </button>
    </div>
    <div
      id="items-sm-navbar"
      class="flex justify-start items-start flex-col gap-3 text-xl duration-500"
    >
      <a href="#experience" class={navLinkClass} aria-label="Work experience"
        >Experience</a
      >
      <a
        href="#freelance-projects"
        class={navLinkClass}
        aria-label="Freelance projects">Freelance projects</a
      >
      <a href="#about-me" class={navLinkClass} aria-label="About me">About</a>
      <a href="#contact" class={navLinkClass} aria-label="Contact">Contact</a>
    </div>
  </nav>
</header>

<script lang="ts">
  const openButton = document.querySelector("#open-button");
  const header = document.querySelector("body > header");
  const links = document.querySelectorAll("body > header a");
  const iconsNavbar = openButton?.querySelectorAll("svg");
  const setExpanded = (open: boolean) => {
    openButton?.setAttribute("aria-expanded", open ? "true" : "false");
    openButton?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  };
  openButton?.addEventListener("click", () => {
    header?.classList.toggle("h-[70px]");
    header?.classList.toggle("h-[270px]");
    const expanded = header?.classList.contains("h-[270px]");
    setExpanded(!!expanded);
    iconsNavbar?.forEach((icon) => {
      icon.classList.toggle("opacity-0");
      icon.classList.toggle("opacity-100");
    });
  });
  links.forEach((link) => {
    link.addEventListener("click", () => {
      header?.classList.add("h-[70px]");
      header?.classList.remove("h-[270px]");
      setExpanded(false);
      iconsNavbar?.item(0)?.classList.add("opacity-100");
      iconsNavbar?.item(0)?.classList.remove("opacity-0");
      iconsNavbar?.item(1)?.classList.add("opacity-0");
      iconsNavbar?.item(1)?.classList.remove("opacity-100");
    });
  });
</script>
<style>
  header {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @media (prefers-reduced-motion: reduce) {
    header {
      animation: none;
    }
  }

  @keyframes nav-shadown {
    to {
      @apply shadow-lg ring-1 backdrop-blur bg-[#181822f1] ring-white/10;
    }
  }
</style>
