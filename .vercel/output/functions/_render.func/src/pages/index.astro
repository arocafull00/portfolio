---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import TimeLine from "../components/TimeLine.astro";
import FreelanceProjects from "@components/FreelanceProjects.astro";
import AboutMe from "@components/AboutMe.astro";
import Contact from "@components/Contact.astro";

const title =
  "Adrian Rocafull — React, TypeScript, Next.js, React Native & Node.js developer";
const description =
  "Full-stack developer from Valencia with 4+ years of experience building web and mobile products with React, TypeScript, Next.js, React Native, Expo, and Node.js — plus AWS when the stack calls for it.";
---

<Layout title={title} description={description}>
  <main id="main-content" tabindex="-1">
    <Hero />
    <TimeLine />
    <FreelanceProjects />
    <AboutMe />
    <Contact />
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 1rem;
    width: 800px;
    max-width: calc(100% - 2rem);
    color: white;
    font-size: 20px;
    line-height: 1.6;
  }
</style>
